# Copy this file to .env.local for development. All values below point at your
# OWN local SpacetimeDB instance — never point a dev client at the production database.

# WebSocket URI of the SpacetimeDB instance the client connects to (your local `spacetime start`).
VITE_SPACETIMEDB_URI=ws://localhost:3000

# Name of the module published to that instance (see "Getting started" in the README).
VITE_MODULE_NAME=bitwars-local

# Path the client returns to after an OAuth provider redirect (defaults to "/").
# VITE_AUTH_CALLBACK_PATH=/

# Optional Discord OAuth entry URL — leave commented out to disable the Discord login button (guest login always works).
# VITE_DISCORD_AUTH_URL=

# Optional Google OAuth entry URL — leave commented out to disable the Google login button.
# VITE_GOOGLE_AUTH_URL=

# Optional Steam OAuth entry URL — leave commented out to disable the Steam login button.
# VITE_STEAM_AUTH_URL=
